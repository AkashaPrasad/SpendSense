# Copy this file to .env and fill in the blanks. Never commit the real .env.

NODE_ENV=development
PORT=4000

# Local Postgres started via `docker compose up -d` from the repo root.
DATABASE_URL="postgresql://spendsense:spendsense@localhost:5433/spendsense?schema=public"

# --- Gemini (server-side ONLY — never shipped to the Flutter client) ---
# Get a free-tier key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"

# --- Firebase Admin (verifies ID tokens sent by the Flutter app) ---
FIREBASE_PROJECT_ID="xenon-world-502717-f0"
# Path to the service account JSON key (already generated in backend/secrets/, gitignored).
GOOGLE_APPLICATION_CREDENTIALS="./secrets/firebase-service-account.json"

# --- Misc ---
CORS_ORIGIN="*"
RATE_LIMIT_AI_PER_MINUTE=10
