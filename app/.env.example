# Copy to .env (same folder as pubspec.yaml). No secrets live here — the
# Flutter app never talks to Gemini directly, only to our own backend.

# Android emulator: use http://10.0.2.2:4000 (its alias for the host machine).
# iOS simulator / macOS / web / physical device on the same Wi-Fi: use your
# machine's LAN IP or http://localhost:4000.
BACKEND_BASE_URL=http://localhost:4000
